#!/usr/bin/env bash
set -euo pipefail

skip_server=0
if [ "${1-}" = "--skip-server" ]; then
  skip_server=1
fi

printf '== Backend setup (server/) ==\n'
(
  cd server
  bin/setup --skip-server
)

printf '\n== Frontend setup (house/) ==\n'
(
  cd house
  npm ci
)

if [ "$skip_server" -eq 0 ]; then
  printf '\n== Starting development environment ==\n'
  exec "$(dirname "$0")/dev"
fi
