<!DOCTYPE html>
<html lang="es">
<head>
  <title>Inspiration Store - Acceso</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <style>
    body { background-color: #020617; color: white; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
    .container { background-color: #0f172a; padding: 2rem; border-radius: 8px; border: 1px solid #334155; }
    h2 { color: #f59e0b; }
    form { display: flex; flex-direction: column; gap: 1rem; }
    input { padding: 0.5rem; border-radius: 4px; border: 1px solid #475569; background: #1e293b; color: white; }
    .actions input { background: #f59e0b; color: #020617; font-weight: bold; cursor: pointer; border: none; }
    a { color: #94a3b8; text-decoration: none; font-size: 0.8rem; }
  </style>
</head>
<body>
  <div class="container">
    <%= yield %>
  </div>
</body>
</html>
