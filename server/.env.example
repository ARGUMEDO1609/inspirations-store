# Inspiration Store - Variables de Entorno

## Base de datos
DATABASE_HOST=localhost
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=71258050
DATABASE_NAME=inspiration_store_development
DATABASE_TEST_NAME=inspiration_store_test

# JWT Authentication
DEVISE_JWT_SECRET_KEY=your_secure_random_secret_key_min_32_chars

# Wompi (Producción)
WOMPI_PUBLIC_KEY=WOMPI_PUBLIC_KEY_VALUE
WOMPI_INTEGRITY_KEY=WOMPI_INTEGRITY_KEY_VALUE
WOMPI_EVENT_SECRET=WOMPI_EVENT_SECRET_VALUE
WOMPI_CURRENCY=COP
WOMPI_FAKE_MODE=false
WOMPI_FAKE_PUBLIC_KEY=pk_test_stub
WOMPI_FAKE_INTEGRITY_KEY=fake_integrity_key

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# Action Cable (Production)
CABLE_URL=wss://your-domain.com/cable

# Active Storage (Production)
# AWS_S3_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1

# SMTP (Production)
# SMTP_ADDRESS=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER_NAME=your-email@domain.com
# SMTP_PASSWORD=your_smtp_password

# Redis (Production - Optional)
# REDIS_URL=redis://localhost:6379/1
